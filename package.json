{
  "name": "go-test",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "go-test GitHub action",
  "main": "dist/index.cjs",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/index.cjs --sourcemap",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "lint": "eslint src/**/*.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "all": "npm run typecheck && npm run format && npm run lint && npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conventional-actions/go-test.git"
  },
  "homepage": "https://github.com/conventional-actions/go-test",
  "bugs": {
    "url": "https://github.com/conventional-actions/go-test/issues"
  },
  "keywords": [
    "GitHub",
    "action",
    "golang",
    "test"
  ],
  "author": "Conventional Actions",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/glob": "^0.3.0",
    "@conventional-actions/toolkit": "^1.1.5",
    "glob": "^8.0.3"
  },
  "devDependencies": {
    "@types/glob": "^8.0.0",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "esbuild": "^0.25.0",
    "eslint": "^8.56.0",
    "eslint-plugin-github": "^5.1.8",
    "eslint-plugin-jest": "^27.2.1",
    "eslint-plugin-prettier": "^5.2.0",
    "jest": "^29.7.0",
    "js-yaml": "^4.1.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.8.0"
  }
}
